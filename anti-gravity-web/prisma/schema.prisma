generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  role          String    @default("user") // 'user', 'admin', 'therapist'
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile           Profile?
  moodLogs          MoodLog[]
  gamificationState GamificationState?
  userBadges        UserBadge[]
  voiceAnalyses     VoiceAnalysis[]
  journalEntries    JournalEntry[]
  dailyChallenges   DailyChallenge[]
  appointments      Appointment[]
}

model Profile {
  userId               String @id
  user                 User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName             String?
  emergencyContactName String?
  emergencyContactPhone String?
  companionPersona     String @default("Supportive Friend")
  preferences          String   @default("{}")
}

model MoodLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moodScore   Int      // 1 to 10
  stressScore Int      @default(5) // 1 to 10
  notes       String?
  loggedAt    DateTime @default(now())
}

model GamificationState {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak Int      @default(0)
  highestStreak Int      @default(0)
  level         String   @default("Beginner")
  xp            Int      @default(0)
  lastCheckIn   DateTime?
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  iconUrl     String?
  users       UserBadge[]
}

model UserBadge {
  userId     String
  badgeId    String
  unlockedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
}

model VoiceAnalysis {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioS3Key       String?
  detectedEmotions String?
  speechMetrics    String?
  recommendations  String?
  analyzedAt       DateTime @default(now())
}

model JournalEntry {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  content     String
  aiSummary   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DailyChallenge {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  isCompleted Boolean  @default(false)
  date        DateTime @default(now())
}

model Appointment {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialistId   Int
  specialistName String
  date           String
  time           String
  reason         String?
  status         String   @default("Confirmed")
  createdAt      DateTime @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
